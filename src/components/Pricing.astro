---
---

<section class="pricing">
  <div class="pricing-container">
    <h2 class="pricing-title">Simple, honest pricing</h2>
    <div class="pricing-grid">
      <!-- Free -->
      <div class="pricing-card">
        <div class="pricing-plan">Free</div>
        <div class="pricing-price">$0<span>/mo</span></div>
        <ul class="pricing-features">
          <li>2 tailoring sessions</li>
          <li>ATS-optimized resume bullets</li>
          <li>ATS keyword scan</li>
        </ul>
        <div class="pricing-cta-placeholder"></div>
      </div>
      <!-- Pro -->
      <div class="pricing-card pricing-card-pro">
        <div class="pricing-badge">Most Popular</div>
        <div class="pricing-plan">Pro</div>
        <div class="pricing-price pricing-price-pro">$12<span>/mo</span></div>
        <ul class="pricing-features pricing-features-pro">
          <li>Unlimited sessions</li>
          <li>Cover letter generator</li>
          <li>ATS match score</li>
          <li>Interview prep</li>
        </ul>
        <a href="#stripe-link" class="btn-gold pricing-cta">Upgrade to Pro</a>
      </div>
      <!-- Teams -->
      <div class="pricing-card">
        <div class="pricing-plan">Teams</div>
        <div class="pricing-price">$49<span>/mo</span></div>
        <ul class="pricing-features">
          <li>Everything in Pro</li>
          <li>Up to 5 users</li>
          <li>Priority support</li>
        </ul>
        <a href="mailto:hello@jobtailor.ai?subject=Teams%20Plan" class="btn-outline pricing-cta">Contact us</a>
      </div>
    </div>
    <p class="pricing-note">No fake reviews. No inflated numbers. Try it free and judge for yourself.</p>
  </div>
</section>

<style>
  .pricing {
    background: var(--ink);
    padding: 80px 0;
  }

  .pricing-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .pricing-title {
    font-family: 'Fraunces', serif;
    font-size: 56px;
    line-height: 64px;
    color: var(--white);
    text-align: center;
    margin-bottom: 56px;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 40px;
  }

  .pricing-card {
    background: var(--white);
    border-radius: 16px;
    padding: 40px;
    position: relative;
  }

  .pricing-card-pro {
    background: var(--forest);
    border: 2px solid var(--gold);
  }

  .pricing-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gold);
    color: var(--forest);
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600;
    font-size: 12px;
    padding: 6px 16px;
    border-radius: 20px;
  }

  .pricing-plan {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600;
    font-size: 14px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }

  .pricing-card-pro .pricing-plan {
    color: rgba(255, 255, 255, 0.7);
  }

  .pricing-price {
    font-family: 'Fraunces', serif;
    font-size: 48px;
    color: var(--forest);
    margin-bottom: 24px;
  }

  .pricing-price span {
    font-size: 18px;
    color: var(--muted);
  }

  .pricing-price-pro {
    color: var(--white);
  }

  .pricing-price-pro span {
    color: rgba(255, 255, 255, 0.6);
  }

  .pricing-features {
    list-style: none;
    margin-bottom: 32px;
  }

  .pricing-features li {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 15px;
    line-height: 24px;
    color: var(--muted);
    padding: 8px 0;
    padding-left: 24px;
    position: relative;
  }

  .pricing-features li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--forest);
    font-weight: 600;
  }

  .pricing-features-pro li {
    color: rgba(255, 255, 255, 0.8);
  }

  .pricing-features-pro li::before {
    color: var(--gold);
  }

  .pricing-cta {
    width: 100%;
    text-align: center;
  }

  .pricing-cta-placeholder {
    height: 48px;
  }

  .pricing-note {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    color: var(--muted);
    text-align: center;
    letter-spacing: 0.3px;
  }

  @media (max-width: 768px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }

    .pricing-title {
      font-size: 40px;
      line-height: 48px;
    }
  }
</style>
