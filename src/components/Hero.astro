<section class="hero">
  <div class="hero-container">
    <div class="hero-badge fade-up fade-up-delay-1">
      🚀 Just launched — try it free, no card needed
    </div>
    <h1 class="hero-title fade-up fade-up-delay-2">
      <span>Tailor your resume.</span>
      <span>Land the interview.</span>
    </h1>
    <p class="hero-subtext fade-up fade-up-delay-3">
      Paste a job description and your experience. Get ATS-ready resume bullets, a cover letter, and interview prep — instantly.
    </p>
    <div class="hero-buttons fade-up fade-up-delay-4">
      <a href="#tool" class="btn-gold">Tailor my resume free →</a>
      <a href="#how-it-works" class="btn-outline">See how it works</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 140px 0 80px;
    text-align: center;
  }

  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .hero-badge {
    display: inline-block;
    background: var(--cream2);
    color: var(--forest);
    padding: 8px 20px;
    border-radius: 20px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.3px;
    margin-bottom: 32px;
  }

  .hero-title {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: 88px;
    line-height: 96px;
    color: var(--forest);
    margin-bottom: 24px;
  }

  .hero-title span {
    display: block;
  }

  .hero-subtext {
    max-width: 560px;
    margin: 0 auto 40px;
    color: var(--muted);
    font-size: 18px;
    line-height: 28px;
  }

  .hero-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 120px 0 60px;
    }

    .hero-title {
      font-size: 48px;
      line-height: 56px;
    }

    .hero-buttons {
      flex-direction: column;
      align-items: center;
    }

    .hero-buttons .btn-gold,
    .hero-buttons .btn-outline {
      width: 100%;
      max-width: 320px;
    }
  }
</style>
