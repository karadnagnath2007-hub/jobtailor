---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TailoringTool from '../components/TailoringTool.jsx';
---

<Base title="Free AI Cover Letter Generator — Personalized, Not Generic" description="Generate a tailored cover letter in 30 seconds. Paste the job description, add your background, get a cover letter that actually fits the role.">
  <Nav />
  <main>
    <section class="tool-hero">
      <div class="container text-center" style="padding-top: 140px; padding-bottom: 48px;">
        <h1 style="font-family: 'Fraunces', serif; font-size: 56px; line-height: 64px; color: var(--forest); margin-bottom: 16px;">
          Stop sending the same cover letter to every job.
        </h1>
        <p style="font-size: 18px; line-height: 28px; color: var(--muted); max-width: 600px; margin: 0 auto;">
          Get a personalized cover letter tailored to the specific job description — in 30 seconds, not 30 minutes.
        </p>
      </div>
    </section>
    <TailoringTool client:load defaultTab="cover" />
  </main>
  <Footer />
</Base>

<style>
  main {
    min-height: 100vh;
  }
</style>
