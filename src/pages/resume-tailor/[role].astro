---export const prerender = true;
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import TailoringTool from '../../components/TailoringTool.jsx';

export async function getStaticPaths() {
  const roles = await getCollection('roles');
  return roles.map((role) => ({
    params: { role: role.data.slug },
    props: { role: role.data },
  }));
}

const { role } = Astro.props;
---

<Base title={`Tailor Your ${role.name} Resume to Any Job Description`} description={`Get ATS-optimized resume bullets, a cover letter, and interview prep tailored for ${role.name} roles.`}>
  <Nav />
  <main>
    <section class="role-hero">
      <div class="container" style="padding-top: 140px; padding-bottom: 48px;">
        <h1 style="font-family: 'Fraunces', serif; font-size: 56px; line-height: 64px; color: var(--forest); margin-bottom: 16px;">
          The {role.name} resume tailoring tool
        </h1>
        <p style="font-size: 18px; line-height: 28px; color: var(--muted); max-width: 640px; margin-bottom: 40px;">
          {role.description}
        </p>

        <div class="role-bullets-preview">
          <h3 style="font-family: 'Fraunces', serif; font-size: 20px; color: var(--forest); margin-bottom: 16px;">Example bullet points</h3>
          <ul style="list-style: none;">
            {role.bullets.map((bullet) => (
              <li style="display: flex; gap: 12px; padding: 10px 0; font-size: 15px; line-height: 24px; color: var(--ink); border-bottom: 1px solid var(--cream2);">
                <span style="color: var(--forest2); font-weight: 700; flex-shrink: 0;">✓</span>
                {bullet}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
    <TailoringTool client:load defaultRole={role.name} />
  </main>
  <Footer />
</Base>

<style>
  main {
    min-height: 100vh;
  }

  .role-bullets-preview {
    background: var(--white);
    border-radius: 12px;
    padding: 32px;
    box-shadow: var(--shadow);
    max-width: 720px;
  }
</style>
